{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "graph.schema.json",
  "title": "CYS Harness graph.json",
  "description": "The central harness contract. Spine field names MUST NOT be renamed. emit_orchestrator.py, validate_harness.py, and the pre-flight cost band (warrant.py) all derive from this file; emit stamps a graph.lock (sha256 provenance). edges express scheduling ORDER (from runs before to; pipeline/parallel/loop) — they are NOT a literal field on the runtime, but the team emitter DERIVES each task's TaskCreate depends_on from the incoming edges (edge to==node => that node depends on the edge's from).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "harness_name", "harness_version", "execution_mode", "topology", "budget", "nodes", "edges"],
  "properties": {
    "schema_version": { "const": "0.1" },
    "harness_name": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,48}[a-z0-9]$" },
    "harness_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "execution_mode": { "type": "string", "enum": ["workflow", "team", "agent", "hybrid"] },
    "topology": { "type": "string", "enum": ["pipeline", "dispatch", "fan-out-fan-in", "producer-reviewer", "supervisor", "expert-pool", "hierarchical"] },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_tokens", "approval_required"],
      "properties": {
        "total_tokens": { "type": ["integer", "null"], "minimum": 1 },
        "approval_required": { "type": "boolean" }
      },
      "if": { "properties": { "approval_required": { "const": true } } },
      "then": { "properties": { "total_tokens": { "type": "integer", "minimum": 1 } } }
    },
    "nodes": { "type": "array", "minItems": 1, "maxItems": 1000, "items": { "$ref": "#/$defs/node" } },
    "edges": { "type": "array", "items": { "$ref": "#/$defs/edge" } },
    "metadata": { "type": "object" }
  },
  "$defs": {
    "modelTier": { "type": "string", "enum": ["haiku", "sonnet", "opus"] },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": { "from": { "type": "string" }, "to": { "type": "string" } }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "agent", "model", "decision_mechanism", "mechanism_params", "inputs", "outputs", "write_paths", "output_schema", "retries", "on_exhaust", "max_rounds"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{0,30}[a-z0-9]$" },
        "agent": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,48}[a-z0-9]$" },
        "model": { "$ref": "#/$defs/modelTier" },
        "decision_mechanism": { "type": "string", "enum": ["single", "majority-vote", "debate-with-judge", "reflect-then-revise"] },
        "mechanism_params": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "n": { "type": "integer", "minimum": 2, "maximum": 5 },
            "quorum": { "type": "integer", "minimum": 1 },
            "tie_break": { "type": "string", "enum": ["first", "highest-confidence"] },
            "max_rounds": { "type": "integer", "minimum": 1, "maximum": 3 },
            "judge": { "$ref": "#/$defs/modelTier" },
            "critic": { "$ref": "#/$defs/modelTier" }
          }
        },
        "inputs": { "type": "array", "items": { "type": "string" } },
        "outputs": { "type": "array", "items": { "type": "string" } },
        "write_paths": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "output_schema": { "type": "string" },
        "retries": { "type": "integer", "minimum": 0, "maximum": 3 },
        "on_exhaust": { "type": "string", "enum": ["proceed-with-gap", "force-pass", "escalate"] },
        "max_rounds": { "type": "integer", "minimum": 1, "maximum": 3 },
        "expected_tokens": { "type": "integer", "exclusiveMinimum": 0 },
        "tier_override_reason": { "type": "string" },
        "tools": { "type": "array", "items": { "type": "string" }, "description": "least-privilege tool allowlist stamped into the emitted .claude/agents/<agent>.md frontmatter (primitive substrate runtime-enforces it). Omit to inherit a role-class default." },
        "review": { "type": "object", "additionalProperties": false, "properties": { "agent": { "type": "string" } }, "description": "optional adversarial-review attribute: after this node, the orchestrator spawns this critic agent (e.g. reviewer/fact-checker) as a first-class L2 gate step." },
        "skill_authoring": { "type": "object", "additionalProperties": false, "required": ["mode"], "properties": { "mode": { "type": "string", "enum": ["inline", "skill"] }, "reason": { "type": "string", "enum": ["reuse", "complex", "conditional"] }, "shared_by": { "type": "array", "items": { "type": "string" } } }, "description": "M3 hybrid authoring decision (locked 5): mode='skill' authors a .claude/skills/<harness>-<id>/SKILL.md for this node's 'how' when it is reused/complex/conditional; mode='inline' (default) keeps the 'how' in the agent body. reason is machine-checked (reuse -> shared_by>=2)." }
      },
      "allOf": [
        {
          "if": { "properties": { "decision_mechanism": { "const": "majority-vote" } } },
          "then": { "properties": { "mechanism_params": { "required": ["n", "quorum"] } } }
        },
        {
          "if": { "properties": { "decision_mechanism": { "const": "debate-with-judge" } } },
          "then": { "properties": { "mechanism_params": { "required": ["max_rounds", "judge"] } } }
        },
        {
          "if": { "properties": { "decision_mechanism": { "const": "reflect-then-revise" } } },
          "then": { "properties": { "mechanism_params": { "required": ["max_rounds", "critic"] } } }
        }
      ]
    }
  }
}
